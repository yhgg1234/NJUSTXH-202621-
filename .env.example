# XH-202621 环境变量配置模板
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ==============================
# 基础配置
# ==============================
DEBUG=true

# ==============================
# Neo4j 图数据库
# ==============================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123
NEO4J_DATABASE=neo4j

# ==============================
# MySQL 关系数据库
# ==============================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=job_graph

# ==============================
# MongoDB 文档数据库
# ==============================
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=job_data

# ==============================
# 大模型服务
# ==============================
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=spark-x2

# ==============================
# 服务端口
# ==============================
API_PORT=8000
